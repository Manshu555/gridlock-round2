# Gridlock Backend — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to git.

# ── Database (PostgreSQL via Neon) ──────────────────────────────────────────
# Get this from: https://neon.tech → your project → Connection Details
# Use the "pooled" connection string for production on Render.
GRIDLOCK_DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins. Use * for development only.
# GRIDLOCK_CORS_ORIGINS=https://your-app.vercel.app,https://your-custom-domain.com

# ── Logging ──────────────────────────────────────────────────────────────────
# GRIDLOCK_LOG_LEVEL=INFO
